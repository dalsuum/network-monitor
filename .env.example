# Network Monitor - Environment Configuration
# Copy this file to .env and customize for your deployment

# Flask Configuration
SECRET_KEY=
FLASK_ENV=production
FLASK_DEBUG=False

# Database
DATABASE_URI=sqlite:///database.db
# SQLite is the supported local database for this project.

# Server Configuration
HOST=
PORT=5002

# Monitoring Settings
PING_INTERVAL=10  # seconds between checks
PING_COUNT=3      # number of pings per check
PING_TIMEOUT=2    # timeout in seconds

# History Retention
HISTORY_RETENTION_DAYS=30  # keep history for this many days (0 = keep forever)

# Email Alerts (if implemented)
# SMTP_SERVER=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_FROM=
# ALERT_TO=

# Security
# ENABLE_HTTPS=True
# SSL_CERT_PATH=
# SSL_KEY_PATH=

# SSH Monitoring Credentials for APs
AP_USERNAME=
AP_PASSWORD=

# Default antenna alert thresholds used when adding new wireless AP devices.
# These can be tuned per device from Edit Device.
DEFAULT_SIGNAL_THRESHOLD_DBM=-75
DEFAULT_LINK_QUALITY_THRESHOLD=50
DEFAULT_SNR_THRESHOLD_DB=20
